NVIDIA_API_KEY=replace_with_your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=google/gemma-3n-e4b-it
NVIDIA_TEMPERATURE=0.2
NVIDIA_TOP_P=0.7
NVIDIA_MAX_TOKENS=512
NVIDIA_THINKING=
NVIDIA_FREQUENCY_PENALTY=0
NVIDIA_PRESENCE_PENALTY=0

# Role-specific defaults used by the multi-agent router.
NVIDIA_PLANNER_MODEL=google/gemma-3n-e4b-it
NVIDIA_PLANNER_TEMPERATURE=0.2
NVIDIA_PLANNER_TOP_P=0.7
NVIDIA_PLANNER_MAX_TOKENS=2048
NVIDIA_PLANNER_THINKING=

NVIDIA_DRAFTER_MODEL=deepseek-ai/deepseek-v4-pro
NVIDIA_DRAFTER_TEMPERATURE=1
NVIDIA_DRAFTER_TOP_P=0.95
NVIDIA_DRAFTER_MAX_TOKENS=16384
NVIDIA_DRAFTER_THINKING=false

NVIDIA_CODER_MODEL=qwen/qwen3-coder-480b-a35b-instruct
NVIDIA_CODER_TEMPERATURE=0.7
NVIDIA_CODER_TOP_P=0.8
NVIDIA_CODER_MAX_TOKENS=4096
NVIDIA_CODER_THINKING=

NVIDIA_REVIEWER_MODEL=google/gemma-3n-e4b-it
NVIDIA_REVIEWER_TEMPERATURE=0.2
NVIDIA_REVIEWER_TOP_P=0.7
NVIDIA_REVIEWER_MAX_TOKENS=2048
NVIDIA_REVIEWER_THINKING=
NVIDIA_REVIEWER_ENABLE_THINKING=
NVIDIA_REVIEWER_REASONING_BUDGET=
NVIDIA_REVIEWER_STREAM=false
