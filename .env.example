NVIDIA_API_KEY=replace_with_your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=minimaxai/minimax-m2.7
NVIDIA_TEMPERATURE=1
NVIDIA_TOP_P=1
NVIDIA_MAX_TOKENS=4096
NVIDIA_THINKING=

# Role-specific defaults used by the multi-agent router.
NVIDIA_PLANNER_MODEL=minimaxai/minimax-m2.7
NVIDIA_PLANNER_TEMPERATURE=1
NVIDIA_PLANNER_TOP_P=0.95
NVIDIA_PLANNER_MAX_TOKENS=8192
NVIDIA_PLANNER_THINKING=

NVIDIA_DRAFTER_MODEL=deepseek-ai/deepseek-v4-pro
NVIDIA_DRAFTER_TEMPERATURE=1
NVIDIA_DRAFTER_TOP_P=0.95
NVIDIA_DRAFTER_MAX_TOKENS=16384
NVIDIA_DRAFTER_THINKING=false

NVIDIA_CODER_MODEL=qwen/qwen3-coder-480b-a35b-instruct
NVIDIA_CODER_TEMPERATURE=0.7
NVIDIA_CODER_TOP_P=0.8
NVIDIA_CODER_MAX_TOKENS=4096
NVIDIA_CODER_THINKING=

NVIDIA_REVIEWER_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_REVIEWER_TEMPERATURE=0.2
NVIDIA_REVIEWER_TOP_P=0.95
NVIDIA_REVIEWER_MAX_TOKENS=8192
NVIDIA_REVIEWER_THINKING=
NVIDIA_REVIEWER_ENABLE_THINKING=true
NVIDIA_REVIEWER_REASONING_BUDGET=4096
NVIDIA_REVIEWER_STREAM=true
